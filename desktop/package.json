{
  "name": "jarvis-desktop",
  "productName": "JARVIS",
  "version": "1.0.0",
  "description": "JARVIS — Sovereign AI Desktop Command Center by Alfredo Medina Hernandez",
  "main": "main.js",
  "author": {
    "name": "Alfredo Medina Hernandez",
    "email": "MedinaSITech@outlook.com"
  },
  "license": "CPEL-1.0",
  "scripts": {
    "start": "electron .",
    "package:win": "electron-forge package --platform win32 --arch x64",
    "package:mac": "electron-forge package --platform darwin --arch x64",
    "package:linux": "electron-forge package --platform linux --arch x64",
    "make:win": "electron-forge make --platform win32 --arch x64",
    "make:mac": "electron-forge make --platform darwin --arch x64",
    "make:linux": "electron-forge make --platform linux --arch x64",
    "make:all": "npm run make:win && npm run make:mac && npm run make:linux"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.6.0",
    "@electron-forge/maker-deb": "^7.6.0",
    "@electron-forge/maker-dmg": "^7.6.0",
    "@electron-forge/maker-rpm": "^7.6.0",
    "@electron-forge/maker-squirrel": "^7.6.0",
    "@electron-forge/maker-zip": "^7.6.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.6.0",
    "electron": "^39.8.1"
  },
  "config": {
    "forge": "./forge.config.cjs"
  }
}
