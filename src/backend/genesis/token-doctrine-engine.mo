    //=========================================================================
    // FORMA FUNCTIONS (INTERNAL FUEL - NOT WEALTH)
    //=========================================================================
    
    public func generateFORMA(
        state : TokenDoctrineState,
        amount : Nat64,
        source : Text,
        beat : Int
    ) : TokenDoctrineState {
        let newForma = {
            totalGenerated = state.formaCirculation.totalGenerated + amount;
            totalConsumed = state.formaCirculation.totalConsumed;
            currentCirculating = state.formaCirculation.currentCirculating + amount;
            generatedByActivity = if (source == "activity") { 
                state.formaCirculation.generatedByActivity + amount 
            } else { state.formaCirculation.generatedByActivity };
            generatedByHeartbeat = if (source == "heartbeat") { 
                state.formaCirculation.generatedByHeartbeat + amount 
            } else { state.formaCirculation.generatedByHeartbeat };
            generatedByEmergence = if (source == "emergence") { 
                state.formaCirculation.generatedByEmergence + amount 
            } else { state.formaCirculation.generatedByEmergence };
            consumedBySpawn = state.formaCirculation.consumedBySpawn;
            consumedByForge = state.formaCirculation.consumedByForge;
            consumedByOmnis = state.formaCirculation.consumedByOmnis;
            consumedByDefense = state.formaCirculation.consumedByDefense;
            consumedByMemory = state.formaCirculation.consumedByMemory;
            generationRate = state.formaCirculation.generationRate;
            consumptionRate = state.formaCirculation.consumptionRate;
            netFlowRate = state.formaCirculation.netFlowRate;
        };
        
        {
            mthBalance = state.mthBalance;
            seedBalance = state.seedBalance;
            mtcBalance = state.mtcBalance;
            hbtBalance = state.hbtBalance;
            omsBalance = state.omsBalance;
            drtBalance = state.drtBalance;
            antBalance = state.antBalance;
            formaCirculation = newForma;
            creatorReserve = state.creatorReserve;
            mintHistory = state.mintHistory;
            burnHistory = state.burnHistory;
            genesisLocked = state.genesisLocked;
            lockedAtBeat = state.lockedAtBeat;
            totalMintEvents = state.totalMintEvents;
            totalBurnEvents = state.totalBurnEvents;
            totalValueMinted = state.totalValueMinted;
            totalValueBurned = state.totalValueBurned;
        }
    };
    
    public func consumeFORMA(
        state : TokenDoctrineState,
        amount : Nat64,
        sink : Text,
        beat : Int
    ) : Result.Result<TokenDoctrineState, Text> {
        if (state.formaCirculation.currentCirculating < amount) {
            return #err("Insufficient FORMA");
        };
        
        let newForma = {
            totalGenerated = state.formaCirculation.totalGenerated;
            totalConsumed = state.formaCirculation.totalConsumed + amount;
            currentCirculating = state.formaCirculation.currentCirculating - amount;
            generatedByActivity = state.formaCirculation.generatedByActivity;
            generatedByHeartbeat = state.formaCirculation.generatedByHeartbeat;
            generatedByEmergence = state.formaCirculation.generatedByEmergence;
            consumedBySpawn = if (sink == "spawn") { 
                state.formaCirculation.consumedBySpawn + amount 
            } else { state.formaCirculation.consumedBySpawn };
            consumedByForge = if (sink == "forge") { 
                state.formaCirculation.consumedByForge + amount 
            } else { state.formaCirculation.consumedByForge };
            consumedByOmnis = if (sink == "omnis") { 
                state.formaCirculation.consumedByOmnis + amount 
            } else { state.formaCirculation.consumedByOmnis };
            consumedByDefense = if (sink == "defense") { 
                state.formaCirculation.consumedByDefense + amount 
            } else { state.formaCirculation.consumedByDefense };
            consumedByMemory = if (sink == "memory") { 
                state.formaCirculation.consumedByMemory + amount 
            } else { state.formaCirculation.consumedByMemory };
            generationRate = state.formaCirculation.generationRate;
            consumptionRate = state.formaCirculation.consumptionRate;
            netFlowRate = state.formaCirculation.netFlowRate;
        };
        
        #ok({
            mthBalance = state.mthBalance;
            seedBalance = state.seedBalance;
            mtcBalance = state.mtcBalance;
            hbtBalance = state.hbtBalance;
            omsBalance = state.omsBalance;
            drtBalance = state.drtBalance;
            antBalance = state.antBalance;
            formaCirculation = newForma;
            creatorReserve = state.creatorReserve;
            mintHistory = state.mintHistory;
            burnHistory = state.burnHistory;
            genesisLocked = state.genesisLocked;
            lockedAtBeat = state.lockedAtBeat;
            totalMintEvents = state.totalMintEvents;
            totalBurnEvents = state.totalBurnEvents;
            totalValueMinted = state.totalValueMinted;
            totalValueBurned = state.totalValueBurned;
        })
    };
    
    //=========================================================================
    // HELPER FUNCTIONS
    //=========================================================================
    
    func updateCreatorReserve(
        reserve : CreatorReserve,
        tokenType : TokenType,
        amount : Nat64,
        isAdd : Bool
    ) : CreatorReserve {
        let delta = if (isAdd) { amount } else { 0 };  // We don't subtract from reserve
        
        {
            mthReserve = if (tokenType == #MTH) { reserve.mthReserve + delta } else { reserve.mthReserve };
            seedReserve = if (tokenType == #SEED) { reserve.seedReserve + delta } else { reserve.seedReserve };
            mtcReserve = if (tokenType == #MTC) { reserve.mtcReserve + delta } else { reserve.mtcReserve };
            hbtReserve = if (tokenType == #HBT) { reserve.hbtReserve + delta } else { reserve.hbtReserve };
            omsReserve = if (tokenType == #OMS) { reserve.omsReserve + delta } else { reserve.omsReserve };
            drtReserve = if (tokenType == #DRT) { reserve.drtReserve + delta } else { reserve.drtReserve };
            antReserve = if (tokenType == #ANT) { reserve.antReserve + delta } else { reserve.antReserve };
            totalTokenValue = reserve.totalTokenValue + delta;
            ckBtcTreasury = reserve.ckBtcTreasury;
            btcFloorReserve = reserve.btcFloorReserve;
            ckEthTreasury = reserve.ckEthTreasury;
            icpNeuronStake = reserve.icpNeuronStake;
            ethYieldAccumulated = reserve.ethYieldAccumulated;
            nnsStkRewards = reserve.nnsStkRewards;
            masterAccumulator = reserve.masterAccumulator;
            successionRoyaltyPct = reserve.successionRoyaltyPct;
            childOrganismCount = reserve.childOrganismCount;
            totalRoyaltiesReceived = reserve.totalRoyaltiesReceived;
        }
    };
    
    func addMintEvent(history : [MintEvent], event : MintEvent) : [MintEvent] {
        let buffer = Buffer.Buffer<MintEvent>(history.size() + 1);
        for (e in history.vals()) {
            buffer.add(e);
        };
        buffer.add(event);
        // Keep last 1000
        if (buffer.size() > 1000) {
            Buffer.toArray(Buffer.subBuffer(buffer, buffer.size() - 1000, 1000))
        } else {
            Buffer.toArray(buffer)
        }
    };
    
    //=========================================================================
    // QUERY FUNCTIONS
    //=========================================================================
    
    public func getCreatorTotalWealth(reserve : CreatorReserve) : Nat64 {
        reserve.mthReserve +
        reserve.seedReserve +
        reserve.mtcReserve +
        reserve.hbtReserve +
        reserve.omsReserve +
        reserve.drtReserve +
        reserve.antReserve +
        reserve.ckBtcTreasury +
        reserve.ckEthTreasury +
        reserve.icpNeuronStake +
        reserve.ethYieldAccumulated +
        reserve.nnsStkRewards +
        reserve.totalRoyaltiesReceived
    };
    
    public func shouldMintANT(beat : Int, lastMintBeat : Int) : Bool {
        beat - lastMintBeat >= ANT_MINT_INTERVAL
    };
    
    public func getMTHRemaining(state : TokenDoctrineState) : Nat64 {
        MTH_HARD_CAP - state.mthBalance.totalMinted
    };
}
