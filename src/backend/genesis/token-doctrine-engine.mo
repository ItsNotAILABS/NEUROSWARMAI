            lastBurnBeat = state.seedBalance.lastBurnBeat;
            mintCount = state.seedBalance.mintCount + 1;
            burnCount = state.seedBalance.burnCount;
        };
        
        let newReserve = updateCreatorReserve(state.creatorReserve, #SEED, amount, true);
        
        let mintEvent : MintEvent = {
            tokenType = #SEED;
            amount = amount;
            beat = beat;
            reason = reason;
            routedToCreator = true;
        };
        
        {
            mthBalance = state.mthBalance;
            seedBalance = newBalance;
            mtcBalance = state.mtcBalance;
            hbtBalance = state.hbtBalance;
            omsBalance = state.omsBalance;
            drtBalance = state.drtBalance;
            antBalance = state.antBalance;
            formaCirculation = state.formaCirculation;
            creatorReserve = newReserve;
            mintHistory = addMintEvent(state.mintHistory, mintEvent);
            burnHistory = state.burnHistory;
            genesisLocked = state.genesisLocked;
            lockedAtBeat = state.lockedAtBeat;
            totalMintEvents = state.totalMintEvents + 1;
            totalBurnEvents = state.totalBurnEvents;
            totalValueMinted = state.totalValueMinted + amount;
            totalValueBurned = state.totalValueBurned;
        }
    };
    
