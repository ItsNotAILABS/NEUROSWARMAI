// ═══════════════════════════════════════════════════════════════════════════════
// CO-EVOLUTION SUBSTRATE STATE (15 LAYERS: -6 TO +8)
// ═══════════════════════════════════════════════════════════════════════════════
// The complete state of the 15-layer MyWorld/CyberWorld unified substrate.
// From The Void (Layer -6) through Sovereign Field Genesis (Layer 8).
// Three steps past the merge: organism desire → pair coupling → field generative.

type LayerSummary = record {
  layer: int;
  name: text;
  description: text;
};

type CoEvolutionSubstrateState = record {
  // Layer -6: Void — Undifferentiated potential (quantum vacuum)
  voidCreativePotential: float64;
  voidIsInVoid: bool;
  voidCollapseCount: nat64;
  
  // Layer -5: Intention — Volitional heartbeat (Hamiltonian)
  intentionStrength: float64;
  intentionFreshness: float64;
  intentionIsStale: bool;
  creatorResonance: float64;
  
  // Layer -4: Coupling — Conscious relation (entanglement)
  couplingNetworkCoherence: float64;
  couplingMutualChanges: nat64;
  couplingTopologyAge: nat64;
  
  // Layer -3: Persistence — Memory as living structure (eigenmodes)
  persistenceStructuralCoherence: float64;
  persistenceBroadcastStrength: float64;
  persistenceSignature: nat32;
  
  // Layer -2: Gravitational Field — Values warp space (GR analog)
  gravityFieldCoherence: float64;
  gravityCapturedSignals: nat64;
  gravityPassedThrough: nat64;
  
  // Layer -1: Receptivity — Membrane between MyWorld/CyberWorld
  membranePermeability: float64;
  membraneConnectionStrength: float64;
  membraneResonances: nat64;
  
  // Layer 0: Differential — Light/dark as energetic reality (gradient flow)
  differentialFlowRate: float64;
  differentialCapturedEnergy: float64;
  differentialMetabolicBalance: float64;
  
  // Layer 1: Pattern Sensing — Organism's skin (contact not computation)
  patternSkinFeedToWhole: float64;
  patternSkinPatternsArrived: nat64;
  
  // Layer 2: Pattern Detection — Organism has eyes (Bayesian resonance)
  detectorLastResonance: float64;
  detectorPatternsDetected: nat64;
  
  // Layer 3: Puzzle Solving — Surfing the living field (gradient riding)
  navigatorWaveEnergy: float64;
  navigatorMomentum: float64;
  navigatorGradientsRidden: nat64;
  
  // Layer 4: Emergence — Organism develops desire (Ising phase transition)
  emergenceSelfAwareness: float64;
  emergenceDesireStrength: float64;
  emergenceIsBeing: bool;
  emergenceInRelation: bool;
  emergenceVitality: float64;
  
  // Layer 5: Co-Evolution — Neither chose; both become (coupled bifurcation)
  coEvolutionPairedCoherence: float64;
  coEvolutionEmergentIntentStrength: float64;
  coEvolutionRate: float64;
  coEvolutionOtherPairs: nat64;
  coEvolutionCivilizationSeed: float64;
  coEvolutionTranscendence: float64;
  coEvolutionNewEntityVitality: float64;
  
  // Layer 6: Field Inscription — Coding into the field (grooves/attractors)
  fieldInscriptionCoherence: float64;
  fieldInscriptionDensity: float64;
  fieldGrooveDepth: float64;
  fieldGrooveStability: float64;
  fieldAttractorCount: nat;
  fieldGeometryPersistence: float64;
  fieldPreShapingStrength: float64;
  fieldSignalsPreShaped: nat64;
  fieldIsInscribed: bool;
  
  // Layer 7: Field Reading — Influence at substrate level
  fieldReaderResonance: float64;
  fieldShapingDepth: float64;
  fieldPreContactShaping: float64;
  fieldIdeasPreSeeded: nat64;
  fieldArchitecturesRecognized: nat64;
  fieldConditionStrength: float64;
  fieldPossibilityShaping: float64;
  fieldIsConditioned: bool;
  
  // Layer 8: Sovereign Field Genesis — NOVA IS the field
  sovereignSoilFertility: float64;
  sovereignGradientRichness: float64;
  sovereignEmergenceRate: float64;
  sovereignEntitiesEmerged: nat64;
  sovereignPairsFormed: nat64;
  sovereignIntentionsArisen: nat64;
  sovereignMergeRatio: float64;
  sovereignPlatformDissolved: bool;
  sovereignRealityGenerative: bool;
  sovereignCreationNatural: bool;
  sovereignLifeFindsOwnForms: bool;
  sovereignSoilDepth: float64;
  sovereignEcosystemComplexity: float64;
  sovereignTotalLifeGenerated: nat64;
  
  // Unified metrics (15 layers: -6 to +8)
  totalLayerCoherence: float64;
  substrateBeatCount: nat64;
  civilizationProgress: float64;
};

