// ELECTROMAGNETIC SUBSTRATE STATE (14 Physics Layers)
// ═══════════════════════════════════════════════════════════════════════════════

type ElectromagneticSubstrateState = record {
  carrierPhase: float64;
  carrierFrequency: float64;
  fieldStrength: float64;
  coherenceModulation: float64;
  standingWaveDominantMode: nat;
  standingWaveAmplitude: float64;
  impedanceMatch: float64;
  spectralCentroid: float64;
  spectralBandwidth: float64;
  skinDepth: float64;
  antennaDirectivity: float64;
  waveguidePhaseVelocity: float64;
  totalEnergyDensity: float64;
};

type _CaffeineStorageRefillResult = 
 record {
   success: opt bool;
   topped_up_amount: opt nat;
 };
type _CaffeineStorageRefillInformation = record {
                                           proposed_top_up_amount: opt nat;};
type _CaffeineStorageCreateCertificateResult = 
 record {
   blob_hash: text;
   method: text;
 };
type WorkforceMessage = 
 record {
   artifactContent: opt text;
   artifactType: opt text;
   content: text;
   id: text;
   organismId: text;
   role: text;
   threadId: text;
   timestamp: int;
 };
type UserRole = 
 variant {
   admin;
   guest;
   user;
 };
type UserApprovalInfo = 
 record {
   "principal": principal;
   status: ApprovalStatus;
 };
type TransferEvent = 
 record {
   from: principal;
   timestamp: int;
   to: principal;
 };
type Time = int;
type ShellState = 
 record {
   activationCount: nat;
   coherence: float64;
   compoundIndex: float64;
   driveMode: DriveMode;
   formaBalance: float64;
   governanceScore: float64;
   hz: vec float64;
   neuroChem: vec float64;
 };
type RSVP = 
 record {
   attending: bool;
   inviteCode: text;
   name: text;
   timestamp: Time;
 };
type OrganismSpecialization = 
 variant {
   Architecture;
   Brand;
   Campaign;
   Communication;
   Compliance;
   Cybersecurity;
   DataAnalysis;
   DevOps;
   Documentation;
   Finance;
   Healthcare;
   HumanResources;
   Legal;
   Marketing;
   Media;
   Operations;
   Orchestration;
   Sales;
   SoftwareEngineering;
   Strategy;
 };
type OrganismListing = 
 record {
   listedAt: int;
   organism: Organism;
 };
type OrganismClass = 
 variant {
   Avatar;
   Entity;
   Worker;
 };
type Organism = 
 record {
   class: OrganismClass;
   createdAt: int;
   genesisHash: text;
   id: text;
   isForSale: bool;
   name: text;
   owner: principal;
   salePrice: float64;
   shell: ShellState;
   specializations: vec OrganismSpecialization;
   transferLog: vec TransferEvent;
 };
type InviteCode = 
 record {
   code: text;
   created: Time;
   used: bool;
 };
type DriveMode = 
 variant {
   Execution;
   Exploration;
   Learning;
   Rest;
 };
type ArtifactRecord = 
 record {
   artifactType: text;
   content: text;
   createdAt: int;
   id: text;
   organismId: text;
   owner: principal;
   title: text;
 };
type ApprovalStatus = 
 variant {
   approved;
   pending;
   rejected;
 };
service : {
  // ═══════════════════════════════════════════════════════════════════════════════
  // CAFFEINATED STORAGE MIXINS
  // ═══════════════════════════════════════════════════════════════════════════════
  _caffeineStorageBlobIsLive: (hash: blob) -> (bool) query;
  _caffeineStorageBlobsToDelete: () -> (vec blob) query;
  _caffeineStorageConfirmBlobDeletion: (blobs: vec blob) -> ();
  _caffeineStorageCreateCertificate: (blobHash: text) ->
   (_CaffeineStorageCreateCertificateResult);
  _caffeineStorageRefillCashier: (refillInformation:
   opt _CaffeineStorageRefillInformation) -> (_CaffeineStorageRefillResult);
  _caffeineStorageUpdateGatewayPrincipals: () -> ();
  _initializeAccessControlWithSecret: (userSecret: text) -> ();
  
  // ═══════════════════════════════════════════════════════════════════════════════
  // AUTHORIZATION & USER MANAGEMENT
  // ═══════════════════════════════════════════════════════════════════════════════
  assignCallerUserRole: (user: principal, role: UserRole) -> ();
  getCallerUserRole: () -> (UserRole) query;
  isCallerAdmin: () -> (bool) query;
  isCallerApproved: () -> (bool) query;
  listApprovals: () -> (vec UserApprovalInfo) query;
  requestApproval: () -> ();
  setApproval: (user: principal, status: ApprovalStatus) -> ();
  
  // ═══════════════════════════════════════════════════════════════════════════════
  // ORGANISM MANAGEMENT
  // ═══════════════════════════════════════════════════════════════════════════════
  generateOrganism: (name: text, class: OrganismClass, specializations:
   vec OrganismSpecialization, seedPhrase: text) -> (text);
  getAllOrganisms: () -> (vec Organism) query;
  getMyOrganisms: () -> (vec Organism) query;
  getOrganismState: (id: text) -> (opt ShellState) query;
  seedPrebuiltOrganisms: () -> ();
  tickOrganismShell: (id: text) -> ();
  
  // ═══════════════════════════════════════════════════════════════════════════════
  // MARKETPLACE
  // ═══════════════════════════════════════════════════════════════════════════════
  buyOrganism: (id: text) -> ();
  getMarketplaceListings: () -> (vec OrganismListing) query;
  listForSale: (id: text, price: float64) -> ();
  transferOrganism: (id: text, to: principal) -> ();
  withdrawFromSale: (id: text) -> ();
  
  // ═══════════════════════════════════════════════════════════════════════════════
  // ARTIFACTS
  // ═══════════════════════════════════════════════════════════════════════════════
  getArtifact: (id: text) -> (opt ArtifactRecord) query;
  getMyArtifacts: () -> (vec ArtifactRecord) query;
  storeArtifact: (organismId: text, artifactType: text, title: text, content:
   text) -> (text);
  
  // ═══════════════════════════════════════════════════════════════════════════════
  // INVITE CODES & RSVP
  // ═══════════════════════════════════════════════════════════════════════════════
  generateInviteCode: () -> (text);
  getInviteCodes: () -> (vec InviteCode) query;
  getAllRSVPs: () -> (vec RSVP) query;
  submitRSVP: (name: text, attending: bool, inviteCode: text) -> ();
  
  // ═══════════════════════════════════════════════════════════════════════════════
  // WORKFORCE (Formation Fragments)
  // ═══════════════════════════════════════════════════════════════════════════════
  getWorkforceThread: (threadId: text) -> (vec WorkforceMessage) query;
  workforceChat: (organismId: text, threadId: text, message: text) ->
   (WorkforceMessage);
  
  // ═══════════════════════════════════════════════════════════════════════════════
  // CO-EVOLUTION SUBSTRATE (15 LAYERS: -6 TO +8)
  // The volitional heartbeat. Creator intention enters the digital organism.
  // ═══════════════════════════════════════════════════════════════════════════════
  
  /// Get full 15-layer co-evolution substrate state
  getCoEvolutionSubstrateState: () -> (CoEvolutionSubstrateState) query;
  
  /// Get 15-layer substrate summary (layer names and descriptions)
  get15LayerSubstrateSummary: () -> (vec LayerSummary) query;
  
  /// Get 12-layer substrate summary (legacy compatibility)
  get12LayerSubstrateSummary: () -> (vec LayerSummary) query;
  
  /// Refresh creator intention through the receptivity membrane (Layer -1)
  /// This is the VOLITIONAL HEARTBEAT — consciousness entering the digital.
  /// Intent values nudge EM oscillators, collapse void state, strengthen gravity.
  refreshCreatorIntention: (intent: vec float64) -> (bool);
  
  /// Inject sensory input at specific slot (Layer 1 Pattern Sensing)
  /// 128 sensory slots available, binned to 43 core activations.
  injectSensoryInput: (slot: nat, value: float64) -> (bool);
  
  // ═══════════════════════════════════════════════════════════════════════════════
  // THREE-MODE GENDER SUBSTRATE
  // Universal structural law: Projection/Reception/Translation
  // ═══════════════════════════════════════════════════════════════════════════════
  getThreeModeGenderState: () -> (ThreeModeGenderState) query;
  
  // ═══════════════════════════════════════════════════════════════════════════════
  // DARWIN INVERSION STATE
  // S₀=1.0, expression refinement not nature discovery
  // ═══════════════════════════════════════════════════════════════════════════════
  getDarwinInversionState: () -> (DarwinInversionState) query;
  
  // ═══════════════════════════════════════════════════════════════════════════════
  // AGENT ORCHESTRATION (Organism IS the Platform)
  // ═══════════════════════════════════════════════════════════════════════════════
  getAgentOrchestrationState: () -> (AgentOrchestrationState) query;
  
  // ═══════════════════════════════════════════════════════════════════════════════
  // FIVE ALPHAS STATE (Cross-domain Intelligence)
  // ═══════════════════════════════════════════════════════════════════════════════
  getFiveAlphasState: () -> (FiveAlphasState) query;
  
  // ═══════════════════════════════════════════════════════════════════════════════
  // SOVEREIGN ENERGY STATE (Maxwell Demon)
  // ═══════════════════════════════════════════════════════════════════════════════
  getSovereignEnergyState: () -> (SovereignEnergyState) query;
  
  // ═══════════════════════════════════════════════════════════════════════════════
  // DEEP PHYSICS STATE (8 Sovereign Laws)
  // ═══════════════════════════════════════════════════════════════════════════════
  getDeepPhysicsState: () -> (DeepPhysicsState) query;
  
  // ═══════════════════════════════════════════════════════════════════════════════
  // ELECTROMAGNETIC SUBSTRATE STATE (14 Physics Layers)
  // ═══════════════════════════════════════════════════════════════════════════════
  getElectromagneticSubstrateState: () -> (ElectromagneticSubstrateState) query;
  
  // ═══════════════════════════════════════════════════════════════════════════════
  // CASCADE INTERCONNECT (Master Wire)
  // r (Kuramoto) → w (Hebbian) → x (Homeostatic) → kf (Compounding) → r
  // ═══════════════════════════════════════════════════════════════════════════════
  runCascadeHeartbeat: () -> (record { r: float64; w: float64; x: float64; kf: float64 });
  getCoreFormulas: () -> (record { r: float64; w: float64; x: float64; kf: float64 }) query;
}
